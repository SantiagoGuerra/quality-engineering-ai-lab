    "@talent-lab/contracts": "workspace:*",
    "@talent-lab/database": "workspace:*",
    "fastify": "5.10.0",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.0.14",
    "@types/nodemailer": "7.0.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
