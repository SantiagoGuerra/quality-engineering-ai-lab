{
  "mcpServers": {
    "playwright-test": {
      "command": "npx",
      "args": [
        "playwright",
        "run-test-mcp-server"
      ]
    },
    "playwright-browser-experimental": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.78", "--headless", "--isolated"]
    },
    "chrome-devtools-experimental": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@1.6.0", "--headless"]
    },
    "storybook-preview": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    }
  }
}
