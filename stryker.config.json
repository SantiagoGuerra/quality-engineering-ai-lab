{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutate": ["packages/contracts/src/scoring.ts"],
  "ignorePatterns": ["reports/**", "artifacts/**", "playwright-report/**", "test-results/**", "storybook-static/**"],
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "vitest": { "configFile": "vitest.unit.config.ts" },
  "reporters": ["clear-text", "progress", "html", "json"],
  "htmlReporter": { "fileName": "reports/generated/stryker/index.html" },
  "jsonReporter": { "fileName": "reports/generated/stryker/mutation.json" },
  "coverageAnalysis": "perTest",
  "thresholds": { "high": 85, "low": 70, "break": 65 },
  "timeoutMS": 10000,
  "concurrency": 2
}
