{
  "name": "@talent-lab/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/cli.ts migrate",
    "seed": "tsx src/cli.ts seed",
    "reset": "tsx src/cli.ts reset"
  },
  "dependencies": {
    "@talent-lab/contracts": "workspace:*",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "24.0.14",
    "@types/pg": "8.20.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
